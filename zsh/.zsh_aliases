# Software Handling aliases
alias :q='exit'
alias :w='source ~/.zshrc'
alias nautilus='nautilus -w'
alias PegaClasse='xprop | grep WM_CLASS'

# Uni ssh shortcut
alias ufpr="ssh ves22@ssh.c3sl.ufpr.br"

# Courses aliases
alias CI1001='vd ~/Documents/2022.2/CI1001_Programacao1/'
alias CI1210='vd ~/Documents/2022.2/CI1210_Projetos/'
alias CI1056='vd ~/Documents/2022.2/CI1056_alg2/'
alias CI1002='vd ~/Documents/2023.1/CI1002/'
alias CI1057='vd ~/Documents/2023.1/CI1057/'
alias CI1212='vd ~/Documents/2023.1/CI1212/'
alias CI1064='vd ~/Documents/2023.2/CI1064/'

# Navigation aliases
alias ..='vd ..'
alias ...='vd ../..'
alias ....='vd ../../..'
alias .....='vd ../../../..'
alias awedirectory='vd ~/.config/awesome/'
alias vimdirectory='vd ~/.config/nvim/lua/'
alias znth='vd ~/Study/zenith_sanctum/'

# Git aliases
alias gitps='git push'
alias gitPl='git pull'
alias gita='git add'
alias gitc='git commit -m'
alias gits='git status'
alias gitres='git restore'

# Apps shortcuts
alias nv='nvim'
alias lgsim='java -jar ~/.logisim/logisim-evolution-3.8.0-all.jar'
alias py3='python3.11'

# Laziness aliases
alias snippets='vd ~/.config/nvim/after/snippets/'

# Configurations aliases
alias .zshconfig='nvim ~/.config/zsh/.zshrc'
alias Aliases='nvim ~/.config/zsh/.zsh_aliases'
alias Functions='nvim ~/.config/zsh/.zsh_functions'
alias .p10kconfig='nvim ~/.config/zsh/.p10k.zsh'
alias vimconfig='nvim ~/.config/nvim/lua/'
alias aweconfig='nvim ~/.config/awesome/rc.lua'
alias kitconfig='nvim ~/.config/kitty/kitty.conf'
alias picconfig='nvim ~/.config/picom/picom.conf'
