ResetHS () {
    echo -e "disconnect 60:F4:3A:A2:2C:44" | bluetoothctl
    sleep 5
    echo -e "connect 60:F4:3A:A2:2C:44" | bluetoothctl
}

zns () {
    if [[ $# -eq 1 ]]; then
        vd ~/zenithSanctum/$1
    else
        vd ~/zenithSanctum/
    fi
}

