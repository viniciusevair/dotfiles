take () {
    mkdir -p $1 && cd $1
}

Run () {
    if [[ $1 == *.c ]]; then
        FILE_SRC=$(basename "$1" .c)
        gcc -Wall -g "$FILE_SRC.c" -o "$FILE_SRC" -lm
        "./$FILE_SRC"
    elif [[ $1 == *.s ]]; then
        FILE_SRC=$(basename "$1" .s)
        as -g "$FILE_SRC.s" -o "$FILE_SRC.o"
        ld -g "$FILE_SRC.o" -o "$FILE_SRC"
        "./$FILE_SRC"
    elif [[ $1 == *.java ]]; then
        FILE_SRC=$(basename "$1" .java)
        javac "$FILE_SRC.java"
        java "$FILE_SRC"
    else
        echo "Formato de arquivo não suportado."
    fi
}

